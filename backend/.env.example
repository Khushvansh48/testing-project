# ─────────────────────────────────────────────────────────────────────────────
# KangPOS Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — this example file only has placeholders.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Security ──────────────────────────────────────────────────────────────────
# Minimum 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=kangpos
DB_PASSWORD=
DB_NAME=pos_db
DB_SSL=false

# ── CORS / Public URLs ────────────────────────────────────────────────────────
# The public URL(s) of your frontend — comma-separated, no trailing slash
FRONTEND_URL=http://35.154.251.72
# Backend's own public URL (used by Xero OAuth callback)
CLIENT_URL=http://35.154.251.72

# ── File Uploads ──────────────────────────────────────────────────────────────
# Absolute path on the server — must live OUTSIDE the deploy directory
# so it survives auto-deploys. Nginx serves this path directly.
UPLOAD_DIR=/var/www/kangpos/uploads

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use a Gmail App Password — NOT your account password.
# Create one at: myaccount.google.com/apppasswords
SYSTEM_EMAIL=
SYSTEM_EMAIL_PASSWORD=
OWNER_ALERT_EMAIL=

# ── Redis (optional — token version cache for multi-instance deployments) ─────
# Leave blank to use in-memory cache (fine for single-server setups)
# REDIS_URL=redis://127.0.0.1:6379

# ── OpenAI (AI chat widget) ───────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Xero (Payroll — AUD only) ─────────────────────────────────────────────────
# Register your app at developer.xero.com
# Add XERO_REDIRECT_URI exactly as registered in your Xero app dashboard
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://35.154.251.72/xero/callback
# When you add a domain, update all 35.154.251.72 entries above to the domain name

# ── AWS S3 (optional — leave blank to use local UPLOAD_DIR instead) ───────────
# AWS_S3_BUCKET=
# AWS_REGION=ap-southeast-2